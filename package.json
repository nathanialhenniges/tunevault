{
  "name": "tunevault",
  "productName": "TuneVault",
  "version": "2.5.0",
  "description": "A desktop app to download YouTube playlists as high-quality audio (FLAC, MP3, Opus) with iTunes metadata tagging, a built-in music player, and customizable track ordering.",
  "main": "./out/main/index.js",
  "author": {
    "name": "nathanialhenniges",
    "email": "nathanialhenniges@users.noreply.github.com"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "download-binaries": "node scripts/download-binaries.mjs"
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@heroicons/react": "^2.2.0",
    "@tanstack/react-virtual": "^3.14.3",
    "electron-updater": "^6.8.9",
    "howler": "^2.2.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/howler": "^2.2.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9"
  }
}
